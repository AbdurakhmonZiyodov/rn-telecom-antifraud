{
  "name": "rn-telecom-antifraud",
  "version": "1.0.1",
  "description": "React Native wrapper for the Telecom AntiFraud (TBM/RTMC) SDK — Promise-based, single configure step, init/recovery helpers built in.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\" \"docs/**/*.md\" \"*.md\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\" \"docs/**/*.md\" \"*.md\"",
    "prepare": "bob build",
    "build": "bob build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "antifraud",
    "telecom-antifraud",
    "uz.tbm.antifraud",
    "rtmc"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdurakhmonZiyodov/rn-telecom-antifraud.git"
  },
  "author": "AbdurakhmonZiyodov",
  "license": "UNLICENSED",
  "private": false,
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "devDependencies": {
    "@react-native/eslint-config": "0.80.3",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "react": "18.3.1",
    "react-native": "0.80.3",
    "react-native-builder-bob": "^0.32.0",
    "typescript": "^5.3.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
